@model List<Coupon>
@{
    ViewData["Title"] = "Coupon Management";
    var searchTerm = ViewBag.SearchTerm as string;
    var filterStatus = ViewBag.FilterStatus as string ?? "all";
}

<!-- Page Header -->
<div class="page-header mb-4">
    <div class="row align-items-center">
        <div class="col-md-6">
            <h1 class="h3 mb-0 text-navy fw-bold">Coupon Management</h1>
            <p class="text-muted mb-0">Manage discount coupons and promotions</p>
        </div>
        <div class="col-md-6 text-md-end">
            <a href="@Url.Action("Assign", "Coupon")" class="btn btn-info me-2">
                <i class="fas fa-user-tag me-2"></i>Assign Coupons
            </a>
            <a href="@Url.Action("Statistics", "Coupon")" class="btn btn-secondary me-2">
                <i class="fas fa-chart-bar me-2"></i>Statistics
            </a>
            <a href="@Url.Action("Create", "Coupon")" class="btn btn-primary">
                <i class="fas fa-plus me-2"></i>Create Coupon
            </a>
        </div>
    </div>
</div>

<!-- Statistics Cards -->
<div class="row g-3 mb-4">
    <div class="col-md-2">
        <div class="stat-card bg-primary">
            <div class="stat-content">
                <h4 class="stat-number">@ViewBag.TotalCoupons</h4>
                <p class="stat-label">Total Coupons</p>
            </div>
            <div class="stat-icon">
                <i class="fas fa-ticket-alt"></i>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="stat-card bg-success">
            <div class="stat-content">
                <h4 class="stat-number">@ViewBag.ActiveCoupons</h4>
                <p class="stat-label">Active</p>
            </div>
            <div class="stat-icon">
                <i class="fas fa-check-circle"></i>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="stat-card bg-warning">
            <div class="stat-content">
                <h4 class="stat-number">@ViewBag.ExpiredCoupons</h4>
                <p class="stat-label">Expired</p>
            </div>
            <div class="stat-icon">
                <i class="fas fa-clock"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card bg-info">
            <div class="stat-content">
                <h4 class="stat-number">@ViewBag.TotalAssignments</h4>
                <p class="stat-label">Assignments</p>
            </div>
            <div class="stat-icon">
                <i class="fas fa-users"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card bg-dark">
            <div class="stat-content">
                <h4 class="stat-number">@ViewBag.UsedCoupons</h4>
                <p class="stat-label">Used</p>
            </div>
            <div class="stat-icon">
                <i class="fas fa-shopping-cart"></i>
            </div>
        </div>
    </div>
</div>

<!-- Filters -->
<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-5">
                <label class="form-label">Search</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-search"></i></span>
                    <input type="text" name="searchTerm" class="form-control" 
                           placeholder="Search by code or description..." value="@searchTerm">
                </div>
            </div>
            <div class="col-md-3">
                <label class="form-label">Status</label>
                <select name="filterStatus" class="form-select">
                    <option value="all" selected="@(filterStatus == "all")">All Coupons</option>
                    <option value="active" selected="@(filterStatus == "active")">Active Only</option>
                    <option value="expired" selected="@(filterStatus == "expired")">Expired</option>
                    <option value="inactive" selected="@(filterStatus == "inactive")">Inactive</option>
                </select>
            </div>
            <div class="col-md-4 d-flex align-items-end">
                <button type="submit" class="btn btn-outline-primary me-2">
                    <i class="fas fa-filter me-1"></i>Filter
                </button>
                <a href="@Url.Action("Index", "Coupon")" class="btn btn-outline-secondary">
                    <i class="fas fa-times me-1"></i>Clear
                </a>
            </div>
        </form>
    </div>
</div>

<!-- Coupons Table -->
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">Coupons (@Model.Count)</h5>
    </div>
    <div class="card-body">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead class="table-light">
                        <tr>
                            <th>Code</th>
                            <th>Description</th>
                            <th>Type</th>
                            <th>Discount</th>
                            <th>Min Order</th>
                            <th>Expiry</th>
                            <th>Usage</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var coupon in Model)
                        {
                            <tr>
                                <td>
                                    <strong class="text-primary">@coupon.CouponCode</strong>
                                </td>
                                <td>
                                    <span title="@coupon.Description">
                                        @(coupon.Description.Length > 30 ? coupon.Description.Substring(0, 30) + "..." : coupon.Description)
                                    </span>
                                </td>
                                <td>
                                    @if (coupon.DiscountType == "Percentage")
                                    {
                                        <span class="badge bg-info">Percentage</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">Fixed</span>
                                    }
                                </td>
                                <td>
                                    @if (coupon.DiscountType == "Percentage")
                                    {
                                        <span>@coupon.DiscountValue%</span>
                                        @if (coupon.MaxDiscountAmount.HasValue)
                                        {
                                            <small class="text-muted d-block">(Max: ₹@coupon.MaxDiscountAmount)</small>
                                        }
                                    }
                                    else
                                    {
                                        <span>₹@coupon.DiscountValue</span>
                                    }
                                </td>
                                <td>₹@coupon.MinimumOrderAmount.ToString("N0")</td>
                                <td>
                                    @coupon.ExpiryDate.ToString("MMM dd, yyyy")
                                    @if (coupon.ExpiryDate < DateTime.Now)
                                    {
                                        <br><span class="badge bg-danger">Expired</span>
                                    }
                                </td>
                                <td>@coupon.UsageLimit</td>
                                <td>
                                    <button class="btn btn-sm p-0 border-0 coupon-toggle-btn" data-id="@coupon.Id">
                                        @if (coupon.IsActive)
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Inactive</span>
                                        }
                                    </button>
                                </td>
                                <td>
                                    <div class="btn-group" role="group">
                                        <a href="@Url.Action("Assignments", "Coupon", new { id = coupon.Id })"
                                           class="btn btn-sm btn-outline-info" title="View Assignments">
                                            <i class="fas fa-users"></i>
                                        </a>
                                        <a href="@Url.Action("Edit", "Coupon", new { id = coupon.Id })"
                                           class="btn btn-sm btn-outline-primary" title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a href="@Url.Action("Delete", "Coupon", new { id = coupon.Id })"
                                           class="btn btn-sm btn-outline-danger" title="Delete">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="fas fa-ticket-alt fa-4x text-muted mb-3"></i>
                <h5 class="text-muted">No coupons found</h5>
                <p class="text-muted">Create your first coupon to get started</p>
                <a href="@Url.Action("Create", "Coupon")" class="btn btn-primary">
                    <i class="fas fa-plus me-2"></i>Create Coupon
                </a>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        // Toggle coupon status
        document.querySelectorAll('.coupon-toggle-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                const couponId = this.dataset.id;
                if (confirm('Toggle coupon status?')) {
                    fetch('/Coupon/ToggleStatus/' + couponId, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' }
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            location.reload();
                        }
                    })
                    .catch(error => alert('Error toggling status'));
                }
            });
        });
    </script>
}
