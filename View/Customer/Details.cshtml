@model Customer
@{
    ViewData["Title"] = "Customer Details";
}

<!-- Page Header -->
<div class="page-header mb-4">
    <div class="row align-items-center">
        <div class="col-md-6">
            <h1 class="h3 mb-0 text-navy fw-bold">Customer Details</h1>
            <p class="text-muted mb-0">@Model.FirstName @Model.LastName</p>
        </div>
        <div class="col-md-6 text-md-end">
            <div class="btn-group" role="group">
                <button type="button" class="btn btn-outline-@(Model.IsActive ? "warning" : "success")" onclick="toggleStatus()">
                    <i class="fas fa-@(Model.IsActive ? "user-times" : "user-check") me-2"></i>
                    @(Model.IsActive ? "Deactivate" : "Activate")
                </button>
                <a href="@Url.Action("Index", "Customer")" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-2"></i>Back to List
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Customer Overview -->
<div class="row">
    <div class="col-lg-8">
        <!-- Customer Information -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="fas fa-user me-2 text-primary"></i>Customer Information
                </h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <div class="customer-profile text-center mb-4">
                            <div class="avatar-xl mx-auto mb-3">
                                <span class="avatar-title bg-primary text-white rounded-circle">
                                    @Model.FirstName.Substring(0, 1)@Model.LastName.Substring(0, 1)
                                </span>
                            </div>
                            <h4 class="text-navy">@Model.FirstName @Model.LastName</h4>
                            <p class="text-muted mb-2">@Model.Email</p>
                            <span class="badge bg-@(Model.IsActive ? "success" : "secondary") fs-6">
                                @(Model.IsActive ? "Active Customer" : "Inactive Customer")
                            </span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="customer-details">
                            <div class="detail-item mb-3">
                                <label class="fw-semibold text-navy">Customer ID:</label>
                                <p class="mb-0 font-monospace">#@Model.Id</p>
                            </div>

                            <div class="detail-item mb-3">
                                <label class="fw-semibold text-navy">Phone Number:</label>
                                <p class="mb-0">@Model.Phone</p>
                            </div>

                            <div class="detail-item mb-3">
                                <label class="fw-semibold text-navy">Registration Date:</label>
                                <p class="mb-0">@Model.CreatedAt.ToString("MMMM dd, yyyy 'at' HH:mm")</p>
                            </div>

                            <div class="detail-item mb-3">
                                <label class="fw-semibold text-navy">Account Status:</label>
                                <p class="mb-0">
                                    <span class="badge bg-@(Model.IsActive ? "success" : "secondary")">
                                        @(Model.IsActive ? "Active" : "Inactive")
                                    </span>
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.Address))
                {
                    <hr>
                    <div class="address-section">
                        <h6 class="text-navy mb-3">Address Information</h6>
                        <div class="row">
                            <div class="col-md-8">
                                <div class="detail-item mb-2">
                                    <label class="fw-semibold text-navy">Address:</label>
                                    <p class="mb-0">@Model.Address</p>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="detail-item mb-2">
                                    <label class="fw-semibold text-navy">City:</label>
                                    <p class="mb-0">@Model.City</p>
                                </div>
                                @if (!string.IsNullOrEmpty(Model.PostalCode))
                                {
                                    <div class="detail-item">
                                        <label class="fw-semibold text-navy">Postal Code:</label>
                                        <p class="mb-0">@Model.PostalCode</p>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Order History -->
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0">
                    <i class="fas fa-shopping-bag me-2 text-success"></i>Order History (@Model.Orders.Count)
                </h5>
                @if (Model.Orders.Any())
                {
                    <span class="text-muted">Total Spent: ₹@Model.Orders.Sum(o => o.TotalAmount).ToString("N0")</span>
                }
            </div>
            <div class="card-body">
                @if (Model.Orders.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Order #</th>
                                    <th>Date</th>
                                    <th>Items</th>
                                    <th>Amount</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var order in Model.Orders.OrderByDescending(o => o.OrderDate))
                                {
                                    <tr>
                                        <td>
                                            <strong class="text-navy">#@order.OrderNumber</strong>
                                        </td>
                                        <td>
                                            <div>@order.OrderDate.ToString("MMM dd, yyyy")</div>
                                            <small class="text-muted">@order.OrderDate.ToString("HH:mm")</small>
                                        </td>
                                        <td>
                                            <span class="badge bg-secondary">@order.OrderItems.Count items</span>
                                        </td>
                                        <td>
                                            <strong class="text-navy">₹@order.TotalAmount.ToString("N0")</strong>
                                        </td>
                                        <td>
                                            <span class="badge bg-@(order.Status == "Pending" ? "warning" :
                                                                                                                     order.Status == "Confirmed" ? "info" :
                                                                                                                     order.Status == "Shipped" ? "primary" :
                                                                                                                     order.Status == "Delivered" ? "success" : "danger")">
                                        @order.Status
                                    </span>
                                </td>
                                <td>
                                    <a href="@Url.Action("Details", "Order", new { id = order.Id })"
                                       class="btn btn-outline-info btn-sm">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                </td>
                            </tr>
                                                        }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-4">
                        <i class="fas fa-shopping-bag fa-3x text-muted mb-3"></i>
                        <h6 class="text-muted">No orders yet</h6>
                        <p class="text-muted small">This customer hasn't placed any orders.</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Sidebar -->
    <div class="col-lg-4">
        <!-- Customer Statistics -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="fas fa-chart-bar me-2 text-info"></i>Customer Statistics
                </h5>
            </div>
            <div class="card-body">
                <div class="stat-grid">
                    <div class="stat-item text-center mb-3">
                        <h3 class="text-navy mb-1">@Model.Orders.Count</h3>
                        <small class="text-muted">Total Orders</small>
                    </div>

                    <div class="stat-item text-center mb-3">
                        <h3 class="text-navy mb-1">₹@Model.Orders.Sum(o => o.TotalAmount).ToString("N0")</h3>
                        <small class="text-muted">Total Spent</small>
                    </div>

                    <div class="stat-item text-center mb-3">
                        <h3 class="text-navy mb-1">
                            @if (Model.Orders.Any())
                            {
                                <span>₹@((int)Model.Orders.Average(o => (double)o.TotalAmount)).ToString("N0")</span>
                            }
                            else
                            {
                                <span>₹0</span>
                            }
                        </h3>
                        <small class="text-muted">Average Order</small>
                    </div>

                    <div class="stat-item text-center">
                        <h3 class="text-navy mb-1">
                            @if (Model.Orders.Any())
                            {
                                <span>@((DateTime.Now - Model.Orders.OrderByDescending(o => o.OrderDate).First().OrderDate).Days) days</span>
                            }
                            else
                            {
                                <span>Never</span>
                            }
                        </h3>
                        <small class="text-muted">Last Order</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="fas fa-bolt me-2 text-warning"></i>Quick Actions
                </h5>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <button type="button" class="btn btn-outline-info" onclick="sendMessage()">
                        <i class="fas fa-envelope me-2"></i>Send Message
                    </button>

                    <button type="button" class="btn btn-outline-@(Model.IsActive ? "warning" : "success")" onclick="toggleStatus()">
                        <i class="fas fa-@(Model.IsActive ? "user-times" : "user-check") me-2"></i>
                        @(Model.IsActive ? "Deactivate Account" : "Activate Account")
                    </button>

                    <button type="button" class="btn btn-outline-secondary" onclick="exportCustomerData()">
                        <i class="fas fa-download me-2"></i>Export Data
                    </button>

                    <hr>

                    <a href="@Url.Action("Delete", "Customer", new { id = Model.Id })" class="btn btn-outline-danger">
                        <i class="fas fa-trash me-2"></i>Delete Customer
                    </a>
                </div>
            </div>
        </div>

        <!-- Account Timeline -->
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="fas fa-history me-2 text-info"></i>Account Timeline
                </h5>
            </div>
            <div class="card-body">
                <div class="timeline">
                    <div class="timeline-item">
                        <div class="timeline-marker bg-success"></div>
                        <div class="timeline-content">
                            <h6 class="mb-1">Account Created</h6>
                            <small class="text-muted">@Model.CreatedAt.ToString("MMM dd, yyyy HH:mm")</small>
                            <p class="small text-muted mb-0">Customer registered on the platform</p>
                        </div>
                    </div>

                    @if (Model.Orders.Any())
                    {
                        var firstOrder = Model.Orders.OrderBy(o => o.OrderDate).First();
                        <div class="timeline-item">
                            <div class="timeline-marker bg-info"></div>
                            <div class="timeline-content">
                                <h6 class="mb-1">First Order</h6>
                                <small class="text-muted">@firstOrder.OrderDate.ToString("MMM dd, yyyy")</small>
                                <p class="small text-muted mb-0">Order #@firstOrder.OrderNumber - ₹@firstOrder.TotalAmount.ToString("N0")</p>
                            </div>
                        </div>

                        var lastOrder = Model.Orders.OrderByDescending(o => o.OrderDate).First();
                        if (lastOrder.Id != firstOrder.Id)
                        {
                            <div class="timeline-item">
                                <div class="timeline-marker bg-primary"></div>
                                <div class="timeline-content">
                                    <h6 class="mb-1">Latest Order</h6>
                                    <small class="text-muted">@lastOrder.OrderDate.ToString("MMM dd, yyyy")</small>
                                    <p class="small text-muted mb-0">Order #@lastOrder.OrderNumber - ₹@lastOrder.TotalAmount.ToString("N0")</p>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <style>
        .avatar-xl {
            width: 80px;
            height: 80px;
        }

        .avatar-title {
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            font-weight: 600;
        }

        .detail-item {
            margin-bottom: 1rem;
        }

        .stat-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
        }

        .stat-item {
            padding: 1rem;
            background: var(--bg-light-beige);
            border-radius: 0.5rem;
        }

        .timeline {
            position: relative;
            padding-left: 2rem;
        }

        .timeline-item {
            position: relative;
            margin-bottom: 1.5rem;
        }

            .timeline-item:last-child {
                margin-bottom: 0;
            }

        .timeline-marker {
            position: absolute;
            left: -2rem;
            top: 0.25rem;
            width: 12px;
            height: 12px;
            border-radius: 50%;
        }

        .timeline::before {
            content: '';
            position: absolute;
            left: -1.5rem;
            top: 0;
            bottom: 0;
            width: 2px;
            background: #e9ecef;
        }

        .customer-profile {
            border-bottom: 1px solid #e9ecef;
            padding-bottom: 1rem;
        }

        @media (max-width: 768px) {
            .stat-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>

    <script>
        function toggleStatus() {
            const isActive = @(Model.IsActive ? "true" : "false");
            const action = isActive ? 'deactivate' : 'activate';

            if (confirm(`Are you sure you want to ${action} this customer?`)) {
                fetch('@Url.Action("ToggleStatus", "Customer")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                    },
                    body: 'id=@Model.Id'
                })
                .then(response => {
                    if (response.ok) {
                        AdminUtils.showNotification(`Customer ${action}d successfully`, 'success');
                        setTimeout(() => location.reload(), 1500);
                    } else {
                        AdminUtils.showNotification(`Failed to ${action} customer`, 'error');
                    }
                })
                .catch(error => {
                    AdminUtils.showNotification('An error occurred', 'error');
                });
            }
        }

        function sendMessage() {
            const message = prompt('Enter message for customer:');
            if (message && message.trim()) {
                // This would typically send an email or notification
                AdminUtils.showNotification('Message sent to customer successfully', 'success');
            }
        }

        function exportCustomerData() {
            AdminUtils.showNotification('Exporting customer data...', 'info');
            // This would typically generate and download customer data
            setTimeout(() => {
                AdminUtils.showNotification('Customer data exported successfully', 'success');
            }, 2000);
        }
    </script>
}