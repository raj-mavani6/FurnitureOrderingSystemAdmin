@model Category
@{
    ViewData["Title"] = "Add Category";
}

<!-- Page Header -->
<div class="page-header mb-4">
    <div class="row align-items-center">
        <div class="col-md-6">
            <h1 class="h3 mb-0 text-navy fw-bold">Add New Category</h1>
            <p class="text-muted mb-0">Create a new furniture category</p>
        </div>
        <div class="col-md-6 text-md-end">
            <a href="@Url.Action("Index", "Category")" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i>Back to Categories
            </a>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="fas fa-folder-plus me-2 text-gold"></i>Category Information
                </h5>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    <div class="row">
                        <div class="col-md-12 mb-3">
                            <label asp-for="Name" class="form-label">Category Name <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control" placeholder="Enter category name">
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>
                        
                        <div class="col-md-12 mb-3">
                            <label asp-for="Description" class="form-label">Description</label>
                            <textarea asp-for="Description" class="form-control" rows="4" 
                                      placeholder="Enter a brief description of this category"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>
                        
                        <div class="col-md-12 mb-3">
                            <label asp-for="ImageUrl" class="form-label">Image URL</label>
                            <input asp-for="ImageUrl" class="form-control" placeholder="https://example.com/image.jpg">
                            <span asp-validation-for="ImageUrl" class="text-danger"></span>
                            <small class="text-muted">Enter a URL for the category image</small>
                        </div>
                        
                        <div class="col-md-12 mb-4">
                            <div class="form-check form-switch">
                                <input asp-for="IsActive" class="form-check-input" type="checkbox" checked>
                                <label asp-for="IsActive" class="form-check-label">Active Category</label>
                            </div>
                            <small class="text-muted">Inactive categories won't be visible to customers</small>
                        </div>
                    </div>
                    
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-2"></i>Create Category
                        </button>
                        <a href="@Url.Action("Index", "Category")" class="btn btn-outline-secondary">
                            <i class="fas fa-times me-2"></i>Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
    
    <div class="col-lg-4">
        <!-- Preview Card -->
        <div class="card">
            <div class="card-header">
                <h6 class="card-title mb-0">
                    <i class="fas fa-eye me-2 text-info"></i>Preview
                </h6>
            </div>
            <div class="card-body">
                <div class="category-preview">
                    <div class="preview-image mb-3" id="imagePreview">
                        <div class="no-image-preview">
                            <i class="fas fa-folder fa-3x text-muted"></i>
                            <p class="text-muted small mt-2">Image preview</p>
                        </div>
                    </div>
                    <h6 class="text-navy" id="namePreview">Category Name</h6>
                    <p class="text-muted small" id="descPreview">Description will appear here</p>
                </div>
            </div>
        </div>
        
        <!-- Tips Card -->
        <div class="card mt-4">
            <div class="card-header">
                <h6 class="card-title mb-0">
                    <i class="fas fa-lightbulb me-2 text-warning"></i>Tips
                </h6>
            </div>
            <div class="card-body">
                <ul class="list-unstyled mb-0 small">
                    <li class="mb-2">
                        <i class="fas fa-check text-success me-2"></i>
                        Use clear, descriptive names
                    </li>
                    <li class="mb-2">
                        <i class="fas fa-check text-success me-2"></i>
                        Add a description for better SEO
                    </li>
                    <li class="mb-2">
                        <i class="fas fa-check text-success me-2"></i>
                        Use high-quality images (800x600px)
                    </li>
                    <li class="mb-0">
                        <i class="fas fa-check text-success me-2"></i>
                        Keep categories organized
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    
    <style>
        .category-preview {
            text-align: center;
        }
        
        .preview-image {
            height: 150px;
            background: var(--bg-light-beige);
            border-radius: 0.5rem;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }
        
        .preview-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        
        .text-gold {
            color: #D4AF37 !important;
        }
    </style>
    
    <script>
        // Live preview
        document.getElementById('Name').addEventListener('input', function() {
            document.getElementById('namePreview').textContent = this.value || 'Category Name';
        });
        
        document.getElementById('Description').addEventListener('input', function() {
            document.getElementById('descPreview').textContent = this.value || 'Description will appear here';
        });
        
        document.getElementById('ImageUrl').addEventListener('input', function() {
            const preview = document.getElementById('imagePreview');
            if (this.value) {
                preview.innerHTML = `<img src="${this.value}" alt="Preview" onerror="this.parentElement.innerHTML='<div class=\\'no-image-preview\\'><i class=\\'fas fa-exclamation-triangle fa-2x text-warning\\'></i><p class=\\'text-muted small mt-2\\'>Invalid image</p></div>'">`;
            } else {
                preview.innerHTML = '<div class="no-image-preview"><i class="fas fa-folder fa-3x text-muted"></i><p class="text-muted small mt-2">Image preview</p></div>';
            }
        });
    </script>
}
