@model PaymentTransaction
@{
    ViewData["Title"] = "Delete Transaction";
}

<!-- Page Header -->
<div class="page-header mb-4">
    <div class="row align-items-center">
        <div class="col-md-6">
            <h1 class="h3 mb-0 text-navy fw-bold">Delete Transaction</h1>
            <p class="text-muted mb-0">Confirm deletion of transaction</p>
        </div>
        <div class="col-md-6 text-md-end">
            <a href="@Url.Action("Index", "PaymentTransaction")" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i>Back to Transactions
            </a>
        </div>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white">
                <h5 class="card-title mb-0">
                    <i class="fas fa-exclamation-triangle me-2"></i>Confirm Delete
                </h5>
            </div>
            <div class="card-body">
                <div class="alert alert-warning">
                    <i class="fas fa-warning me-2"></i>
                    Are you sure you want to delete this transaction? This action cannot be undone.
                </div>
                
                <div class="row mb-4">
                    <div class="col-md-6">
                        <h6 class="text-muted">Transaction ID</h6>
                        <p class="h5 text-primary">@Model.TransactionId</p>
                    </div>
                    <div class="col-md-6">
                        <h6 class="text-muted">Amount</h6>
                        <p class="h5 text-success">₹@Model.Amount.ToString("N2")</p>
                    </div>
                </div>
                
                <div class="row mb-4">
                    <div class="col-md-4">
                        <h6 class="text-muted">Payment Method</h6>
                        <span class="badge bg-info">@Model.PaymentMethod</span>
                    </div>
                    <div class="col-md-4">
                        <h6 class="text-muted">Status</h6>
                        @{
                            var statusClass = Model.PaymentStatus switch
                            {
                                "Completed" => "success",
                                "Pending" => "warning",
                                "Failed" => "danger",
                                "Refunded" => "secondary",
                                _ => "light"
                            };
                        }
                        <span class="badge bg-@statusClass">@Model.PaymentStatus</span>
                    </div>
                    <div class="col-md-4">
                        <h6 class="text-muted">Date</h6>
                        <p>@Model.TransactionDate.ToString("MMM dd, yyyy")</p>
                    </div>
                </div>
                
                @if (Model.Order != null)
                {
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <h6 class="text-muted">Order Number</h6>
                            <p>@Model.Order.OrderNumber</p>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-muted">Customer</h6>
                            <p>@Model.Order.Customer?.FirstName @Model.Order.Customer?.LastName</p>
                        </div>
                    </div>
                }
                
                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger">
                            <i class="fas fa-trash me-2"></i>Delete Transaction
                        </button>
                        <a href="@Url.Action("Index", "PaymentTransaction")" class="btn btn-outline-secondary">
                            <i class="fas fa-times me-2"></i>Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
