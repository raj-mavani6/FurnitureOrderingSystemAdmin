@model PaymentTransaction
@{
    ViewData["Title"] = "Transaction Details";
}

<!-- Page Header -->
<div class="page-header mb-4">
    <div class="row align-items-center">
        <div class="col-md-6">
            <h1 class="h3 mb-0 text-navy fw-bold">Transaction Details</h1>
            <p class="text-muted mb-0">Transaction: @Model.TransactionId</p>
        </div>
        <div class="col-md-6 text-md-end">
            <a href="@Url.Action("Edit", "PaymentTransaction", new { id = Model.Id })" class="btn btn-primary me-2">
                <i class="fas fa-edit me-2"></i>Edit
            </a>
            <a href="@Url.Action("Index", "PaymentTransaction")" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i>Back to Transactions
            </a>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <!-- Transaction Info Card -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="fas fa-credit-card me-2 text-gold"></i>Transaction Information
                </h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <small class="text-muted">Transaction ID</small>
                        <h5 class="text-primary mb-0">@Model.TransactionId</h5>
                    </div>
                    <div class="col-md-6 mb-3">
                        <small class="text-muted">Amount</small>
                        <h4 class="text-success mb-0">₹@Model.Amount.ToString("N2")</h4>
                    </div>
                    <div class="col-md-4 mb-3">
                        <small class="text-muted">Payment Method</small>
                        <p class="mb-0"><span class="badge bg-info fs-6">@Model.PaymentMethod</span></p>
                    </div>
                    <div class="col-md-4 mb-3">
                        <small class="text-muted">Status</small>
                        @{
                            var statusClass = Model.PaymentStatus switch
                            {
                                "Completed" => "success",
                                "Pending" => "warning",
                                "Failed" => "danger",
                                "Refunded" => "secondary",
                                _ => "light"
                            };
                        }
                        <p class="mb-0"><span class="badge bg-@statusClass fs-6">@Model.PaymentStatus</span></p>
                    </div>
                    <div class="col-md-4 mb-3">
                        <small class="text-muted">Transaction Date</small>
                        <p class="mb-0 fw-bold">@Model.TransactionDate.ToString("MMM dd, yyyy HH:mm")</p>
                    </div>
                </div>
                
                @if (!string.IsNullOrEmpty(Model.Remarks))
                {
                    <div class="mt-3">
                        <small class="text-muted">Remarks</small>
                        <p class="mb-0">@Model.Remarks</p>
                    </div>
                }
                
                @if (!string.IsNullOrEmpty(Model.GatewayResponse))
                {
                    <div class="mt-3">
                        <small class="text-muted">Gateway Response</small>
                        <p class="mb-0 text-muted font-monospace">@Model.GatewayResponse</p>
                    </div>
                }
            </div>
        </div>

        <!-- Order Details Card -->
        @if (Model.Order != null)
        {
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">
                        <i class="fas fa-shopping-bag me-2 text-gold"></i>Order Information
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-4">
                            <small class="text-muted">Order Number</small>
                            <p class="fw-bold mb-0">@Model.Order.OrderNumber</p>
                        </div>
                        <div class="col-md-4">
                            <small class="text-muted">Order Date</small>
                            <p class="mb-0">@Model.Order.OrderDate.ToString("MMM dd, yyyy")</p>
                        </div>
                        <div class="col-md-4">
                            <small class="text-muted">Order Status</small>
                            <p class="mb-0"><span class="badge bg-primary">@Model.Order.Status</span></p>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6 mb-3">
                            <small class="text-muted">Delivery Address</small>
                            <p class="mb-0">
                                @Model.Order.DeliveryAddress<br>
                                @Model.Order.DeliveryCity - @Model.Order.DeliveryPostalCode
                            </p>
                        </div>
                        <div class="col-md-3 mb-3">
                            <small class="text-muted">Contact Phone</small>
                            <p class="mb-0">@Model.Order.ContactPhone</p>
                        </div>
                        <div class="col-md-3 mb-3">
                            <small class="text-muted">Delivery Date</small>
                            <p class="mb-0">@(Model.Order.DeliveryDate?.ToString("MMM dd, yyyy") ?? "N/A")</p>
                        </div>
                    </div>
                    
                    @if (!string.IsNullOrEmpty(Model.Order.Notes))
                    {
                        <div class="row mb-3">
                            <div class="col-12">
                                <small class="text-muted">Order Notes</small>
                                <p class="mb-0 fst-italic">"@Model.Order.Notes"</p>
                            </div>
                        </div>
                    }
                    
                    @if (Model.Order.OrderItems?.Any() == true)
                    {
                        <h6 class="mt-4 mb-3">Order Items</h6>
                        <div class="table-responsive">
                            <table class="table table-sm">
                                <thead class="table-light">
                                    <tr>
                                        <th>Item</th>
                                        <th>Qty</th>
                                        <th class="text-end">Price</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.Order.OrderItems)
                                    {
                                        <tr>
                                            <td>@item.Furniture?.Name</td>
                                            <td>@item.Quantity</td>
                                            <td class="text-end">₹@item.UnitPrice.ToString("N0")</td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot>
                                    <tr class="fw-bold">
                                        <td colspan="2">Total</td>
                                        <td class="text-end">₹@Model.Order.TotalAmount.ToString("N0")</td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    <div class="col-lg-4">
        <!-- Customer Info Card -->
        @if (Model.Order?.Customer != null)
        {
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="card-title mb-0">
                        <i class="fas fa-user me-2 text-gold"></i>Customer
                    </h5>
                </div>
                <div class="card-body">
                    <h6>@Model.Order.Customer.FirstName @Model.Order.Customer.LastName</h6>
                    <p class="text-muted mb-1">
                        <i class="fas fa-envelope me-2"></i>@Model.Order.Customer.Email
                    </p>
                    <p class="text-muted mb-0">
                        <i class="fas fa-phone me-2"></i>@Model.Order.Customer.Phone
                    </p>
                </div>
            </div>
        }

        <!-- Actions Card -->
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="fas fa-cogs me-2 text-gold"></i>Actions
                </h5>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <a href="@Url.Action("Edit", "PaymentTransaction", new { id = Model.Id })" class="btn btn-primary">
                        <i class="fas fa-edit me-2"></i>Edit Transaction
                    </a>
                    <a href="@Url.Action("Delete", "PaymentTransaction", new { id = Model.Id })" class="btn btn-outline-danger">
                        <i class="fas fa-trash me-2"></i>Delete
                    </a>
                    <a href="@Url.Action("Index", "PaymentTransaction")" class="btn btn-outline-secondary">
                        <i class="fas fa-arrow-left me-2"></i>Back
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
