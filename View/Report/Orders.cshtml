@model List<FurnitureOrderingSystemAdmin.Models.Order>
@{
    ViewData["Title"] = "Order Reports";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2>
                        <i class="fas fa-receipt me-2"></i>Order Reports
                    </h2>
                    <p class="text-muted">Track orders by status and performance</p>
                </div>
                <div>
                    <a href="@Url.Action("Index")" class="btn btn-secondary">
                        <i class="fas fa-arrow-left me-1"></i>Back to Reports
                    </a>
                    <a href="@Url.Action("ExportOrdersCSV")" class="btn btn-warning">
                        <i class="fas fa-download me-1"></i>Export CSV
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Summary Cards -->
    <div class="row mb-4">
        <div class="col-md-4 col-lg-2 mb-3">
            <div class="card bg-primary text-white">
                <div class="card-body text-center">
                    <h6 class="card-title">Total Orders</h6>
                    <h3 class="mb-0">@ViewBag.TotalOrders</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4 col-lg-2 mb-3">
            <div class="card bg-warning text-white">
                <div class="card-body text-center">
                    <h6 class="card-title">Pending</h6>
                    <h3 class="mb-0">@ViewBag.PendingOrders</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4 col-lg-2 mb-3">
            <div class="card bg-info text-white">
                <div class="card-body text-center">
                    <h6 class="card-title">Processing</h6>
                    <h3 class="mb-0">@ViewBag.ProcessingOrders</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4 col-lg-2 mb-3">
            <div class="card bg-secondary text-white">
                <div class="card-body text-center">
                    <h6 class="card-title">Shipped</h6>
                    <h3 class="mb-0">@ViewBag.ShippedOrders</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4 col-lg-2 mb-3">
            <div class="card bg-success text-white">
                <div class="card-body text-center">
                    <h6 class="card-title">Delivered</h6>
                    <h3 class="mb-0">@ViewBag.DeliveredOrders</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4 col-lg-2 mb-3">
            <div class="card bg-danger text-white">
                <div class="card-body text-center">
                    <h6 class="card-title">Cancelled</h6>
                    <h3 class="mb-0">@ViewBag.CancelledOrders</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <!-- Order Trend Chart -->
        <div class="col-lg-8 mb-4">
            <div class="card">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="fas fa-chart-line me-2 text-primary"></i>Order Trend
                    </h5>
                    <div class="btn-group btn-group-sm" role="group">
                        <button type="button" class="btn btn-outline-primary" onclick="loadOrderChart('daily')">Daily</button>
                        <button type="button" class="btn btn-outline-primary" onclick="loadOrderChart('weekly')">Weekly</button>
                        <button type="button" class="btn btn-primary" onclick="loadOrderChart('monthly')">Monthly</button>
                        <button type="button" class="btn btn-outline-primary" onclick="loadOrderChart('yearly')">Yearly</button>
                    </div>
                </div>
                <div class="card-body">
                    <div class="chart-container" style="height: 300px;">
                        <canvas id="orderTrendChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <!-- Order Status Distribution -->
        <div class="col-lg-4 mb-4">
            <div class="card">
                <div class="card-header bg-white">
                    <h5 class="mb-0">
                        <i class="fas fa-chart-pie me-2 text-info"></i>Status Distribution
                    </h5>
                </div>
                <div class="card-body">
                    <div class="chart-container" style="height: 300px;">
                        <canvas id="orderStatusChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Filter by Status -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="btn-group" role="group">
                <a href="@Url.Action("Orders")" class="btn @(string.IsNullOrEmpty(ViewBag.SelectedStatus) ? "btn-primary" : "btn-outline-primary")">
                    All Orders
                </a>
                <a href="@Url.Action("Orders", new { status = "Pending" })" class="btn @(ViewBag.SelectedStatus == "Pending" ? "btn-warning" : "btn-outline-warning")">
                    Pending
                </a>
                <a href="@Url.Action("Orders", new { status = "Processing" })" class="btn @(ViewBag.SelectedStatus == "Processing" ? "btn-info" : "btn-outline-info")">
                    Processing
                </a>
                <a href="@Url.Action("Orders", new { status = "Shipped" })" class="btn @(ViewBag.SelectedStatus == "Shipped" ? "btn-secondary" : "btn-outline-secondary")">
                    Shipped
                </a>
                <a href="@Url.Action("Orders", new { status = "Delivered" })" class="btn @(ViewBag.SelectedStatus == "Delivered" ? "btn-success" : "btn-outline-success")">
                    Delivered
                </a>
                <a href="@Url.Action("Orders", new { status = "Cancelled" })" class="btn @(ViewBag.SelectedStatus == "Cancelled" ? "btn-danger" : "btn-outline-danger")">
                    Cancelled
                </a>
            </div>
        </div>
    </div>

    <!-- Orders Table -->
    <div class="card">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">
                <i class="fas fa-list me-2"></i>Order Details
            </h5>
            <span class="badge bg-primary">Avg Order Value: ₹@ViewBag.AverageOrderValue</span>
        </div>
        <div class="card-body">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>Order ID</th>
                                <th>Customer</th>
                                <th>Date</th>
                                <th>Items</th>
                                <th>Total Amount</th>
                                <th>Status</th>
                                <th>Payment</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model)
                            {
                                var paymentMethod = (ViewBag.OrderPaymentMethods as Dictionary<int, string>).ContainsKey(order.Id) ? (ViewBag.OrderPaymentMethods as Dictionary<int, string>)[order.Id] : "N/A";
                                <tr>
                                    <td><strong>#@order.Id</strong></td>
                                    <td>@(order.Customer != null ? $"{order.Customer.FirstName} {order.Customer.LastName}" : "N/A")</td>
                                    <td>@order.OrderDate.ToString("dd MMM yyyy")</td>
                                    <td>@(order.OrderItems?.Count ?? 0)</td>
                                    <td class="text-success"><strong>₹@order.TotalAmount.ToString("N0")</strong></td>
                                    <td>
                                        @switch (order.Status)
                                        {
                                            case "Pending":
                                                <span class="badge bg-warning">Pending</span>
                                                break;
                                            case "Processing":
                                                <span class="badge bg-info">Processing</span>
                                                break;
                                            case "Shipped":
                                                <span class="badge bg-secondary">Shipped</span>
                                                break;
                                            case "Delivered":
                                                <span class="badge bg-success">Delivered</span>
                                                break;
                                            case "Cancelled":
                                                <span class="badge bg-danger">Cancelled</span>
                                                break;
                                            default:
                                                <span class="badge bg-dark">@order.Status</span>
                                                break;
                                        }
                                    </td>
                                    <td>@paymentMethod</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info text-center">
                    <i class="fas fa-info-circle me-2"></i>No orders found.
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        var orderTrendChart;

        // Order Status Distribution Chart
        var statusCtx = document.getElementById('orderStatusChart').getContext('2d');
        new Chart(statusCtx, {
            type: 'doughnut',
            data: {
                labels: ['Pending', 'Processing', 'Shipped', 'Delivered', 'Cancelled'],
                datasets: [{
                    data: [@ViewBag.PendingOrders, @ViewBag.ProcessingOrders, @ViewBag.ShippedOrders, @ViewBag.DeliveredOrders, @ViewBag.CancelledOrders],
                    backgroundColor: ['#ffc107', '#0dcaf0', '#6c757d', '#198754', '#dc3545']
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom'
                    }
                }
            }
        });

        // Load Order Trend Chart
        function loadOrderChart(period) {
            fetch('@Url.Action("GetOrderChartData")?period=' + period)
                .then(response => response.json())
                .then(data => {
                    if (orderTrendChart) {
                        orderTrendChart.destroy();
                    }

                    var ctx = document.getElementById('orderTrendChart').getContext('2d');
                    orderTrendChart = new Chart(ctx, {
                        type: 'line',
                        data: {
                            labels: data.labels,
                            datasets: [{
                                label: 'Orders',
                                data: data.values,
                                borderColor: '#0d6efd',
                                backgroundColor: 'rgba(13, 110, 253, 0.1)',
                                fill: true,
                                tension: 0.4
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: {
                                    display: false
                                }
                            },
                            scales: {
                                y: {
                                    beginAtZero: true
                                }
                            }
                        }
                    });
                });
        }

        // Initialize with monthly data
        loadOrderChart('monthly');
    </script>
}
