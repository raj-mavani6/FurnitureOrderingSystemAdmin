@model List<FurnitureOrderingSystemAdmin.Models.Coupon>
@{
    ViewData["Title"] = "Coupon Reports";
    var couponStats = ViewBag.CouponStats as List<dynamic>;
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2>
                        <i class="fas fa-ticket-alt me-2"></i>Coupon Reports
                    </h2>
                    <p class="text-muted">Track coupon usage and effectiveness</p>
                </div>
                <div>
                    <a href="@Url.Action("Index")" class="btn btn-secondary">
                        <i class="fas fa-arrow-left me-1"></i>Back to Reports
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Summary Cards -->
    <div class="row mb-4">
        <div class="col-md-4 col-lg-2 mb-3">
            <div class="card bg-primary text-white">
                <div class="card-body text-center">
                    <h6 class="card-title">Total Coupons</h6>
                    <h3 class="mb-0">@ViewBag.TotalCoupons</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4 col-lg-2 mb-3">
            <div class="card bg-success text-white">
                <div class="card-body text-center">
                    <h6 class="card-title">Active</h6>
                    <h3 class="mb-0">@ViewBag.ActiveCoupons</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4 col-lg-2 mb-3">
            <div class="card bg-danger text-white">
                <div class="card-body text-center">
                    <h6 class="card-title">Expired</h6>
                    <h3 class="mb-0">@ViewBag.ExpiredCoupons</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4 col-lg-3 mb-3">
            <div class="card bg-info text-white">
                <div class="card-body text-center">
                    <h6 class="card-title">Total Assignments</h6>
                    <h3 class="mb-0">@ViewBag.TotalAssignments</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4 col-lg-3 mb-3">
            <div class="card bg-warning text-dark">
                <div class="card-body text-center">
                    <h6 class="card-title">Total Used</h6>
                    <h3 class="mb-0">@ViewBag.TotalUsed</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Usage Chart -->
        <div class="col-lg-6 mb-4">
            <div class="card">
                <div class="card-header bg-white">
                    <h5 class="mb-0">
                        <i class="fas fa-chart-bar me-2 text-success"></i>Coupon Usage
                    </h5>
                </div>
                <div class="card-body">
                    @if (couponStats != null && couponStats.Any())
                    {
                        <div class="chart-container" style="height: 300px;">
                            <canvas id="couponUsageChart"></canvas>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info text-center">
                            <i class="fas fa-info-circle me-2"></i>No coupon data available.
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Status Distribution -->
        <div class="col-lg-6 mb-4">
            <div class="card">
                <div class="card-header bg-white">
                    <h5 class="mb-0">
                        <i class="fas fa-chart-pie me-2 text-primary"></i>Coupon Status
                    </h5>
                </div>
                <div class="card-body">
                    <div class="chart-container" style="height: 300px;">
                        <canvas id="couponStatusChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Coupon Statistics Table -->
    <div class="card">
        <div class="card-header bg-white">
            <h5 class="mb-0">
                <i class="fas fa-table me-2"></i>Coupon Details
            </h5>
        </div>
        <div class="card-body">
            @if (couponStats != null && couponStats.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>Code</th>
                                <th>Description</th>
                                <th>Discount</th>
                                <th>Valid Period</th>
                                <th class="text-center">Assigned</th>
                                <th class="text-center">Used</th>
                                <th class="text-center">Usage Rate</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var coupon in couponStats)
                            {
                                decimal usageRate = coupon.TotalAssignments > 0 ? ((decimal)coupon.TotalUsed / coupon.TotalAssignments) * 100 : 0;
                                <tr>
                                    <td><strong class="text-primary">@coupon.CouponCode</strong></td>
                                    <td>@(coupon.Description ?? "-")</td>
                                    <td>
                                        @if (coupon.DiscountType == "Percentage")
                                        {
                                            <span class="badge bg-warning text-dark">@coupon.DiscountValue%</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">₹@coupon.DiscountValue</span>
                                        }
                                    </td>
                                    <td>
                                        <small>
                                            @((coupon.StartDate as DateTime?)?.ToString("dd MMM") ?? "-") -
                                            @((coupon.ExpiryDate as DateTime?)?.ToString("dd MMM yyyy") ?? "-")
                                        </small>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-info">@coupon.TotalAssignments</span>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-success">@coupon.TotalUsed</span>
                                    </td>
                                    <td class="text-center">
                                        <div class="progress" style="height: 20px;">
                                            <div class="progress-bar @(usageRate >= 50 ? "bg-success" : usageRate >= 25 ? "bg-warning" : "bg-danger")"
                                                 role="progressbar"
                                                 style="width: @usageRate%"
                                                 aria-valuenow="@usageRate"
                                                 aria-valuemin="0"
                                                 aria-valuemax="100">
                                                @usageRate.ToString("F0")%
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        @if (coupon.IsExpired)
                                        {
                                            <span class="badge bg-danger">Expired</span>
                                        }
                                        else if (coupon.IsActive)
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Inactive</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info text-center">
                    <i class="fas fa-info-circle me-2"></i>No coupons found.
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Coupon Status Chart
        var statusCtx = document.getElementById('couponStatusChart').getContext('2d');
        new Chart(statusCtx, {
            type: 'doughnut',
            data: {
                labels: ['Active', 'Expired', 'Inactive'],
                datasets: [{
                    data: [@ViewBag.ActiveCoupons, @ViewBag.ExpiredCoupons, @(ViewBag.TotalCoupons - ViewBag.ActiveCoupons - ViewBag.ExpiredCoupons)],
                    backgroundColor: ['#198754', '#dc3545', '#6c757d']
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom'
                    }
                }
            }
        });
    </script>

    @{
        var labels = new List<string>();
        var assigned = new List<int>();
        var used = new List<int>();
        var hasData = false;

        if (couponStats != null && couponStats.Any())
        {
            hasData = true;
            var topCoupons = couponStats.Take(5).ToList();
            labels = topCoupons.Select(c => (string)c.CouponCode).ToList();
            assigned = topCoupons.Select(c => (int)c.TotalAssignments).ToList();
            used = topCoupons.Select(c => (int)c.TotalUsed).ToList();
        }
    }

    @if (hasData)
    {
        <script>
            // Data from Server
            var chartLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(labels));
            var chartAssignedData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(assigned));
            var chartUsedData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(used));

            // Coupon Usage Chart
            var usageCtx = document.getElementById('couponUsageChart').getContext('2d');
            new Chart(usageCtx, {
                type: 'bar',
                data: {
                    labels: chartLabels,
                    datasets: [
                        {
                            label: 'Assigned',
                            data: chartAssignedData,
                            backgroundColor: 'rgba(13, 202, 240, 0.8)'
                        },
                        {
                            label: 'Used',
                            data: chartUsedData,
                            backgroundColor: 'rgba(25, 135, 84, 0.8)'
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        y: {
                            beginAtZero: true
                        }
                    }
                }
            });
        </script>
    }
}
