@model List<FurnitureOrderingSystemAdmin.Models.Combo>
@{
    ViewData["Title"] = "Combo Reports";
    var comboStats = ViewBag.ComboStats as List<dynamic>;
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2>
                        <i class="fas fa-layer-group me-2"></i>Combo Reports
                    </h2>
                    <p class="text-muted">Combo packages performance analysis</p>
                </div>
                <div>
                    <a href="@Url.Action("Index")" class="btn btn-secondary">
                        <i class="fas fa-arrow-left me-1"></i>Back to Reports
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Summary Cards -->
    <div class="row mb-4">
        <div class="col-md-3 mb-3">
            <div class="card bg-primary text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h6 class="card-title">Total Combos</h6>
                            <h3 class="mb-0">@ViewBag.TotalCombos</h3>
                        </div>
                        <i class="fas fa-layer-group fa-2x opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h6 class="card-title">Active Combos</h6>
                            <h3 class="mb-0">@ViewBag.ActiveCombos</h3>
                        </div>
                        <i class="fas fa-check-circle fa-2x opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card bg-danger text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h6 class="card-title">Inactive Combos</h6>
                            <h3 class="mb-0">@ViewBag.InactiveCombos</h3>
                        </div>
                        <i class="fas fa-times-circle fa-2x opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card bg-info text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h6 class="card-title">Total Items in Combos</h6>
                            <h3 class="mb-0">@ViewBag.TotalItems</h3>
                        </div>
                        <i class="fas fa-couch fa-2x opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Combo Statistics Table -->
    <div class="card">
        <div class="card-header bg-white">
            <h5 class="mb-0">
                <i class="fas fa-table me-2"></i>Combo Details
            </h5>
        </div>
        <div class="card-body">
            @if (comboStats != null && comboStats.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Combo Name</th>
                                <th>Description</th>
                                <th class="text-center">Items</th>
                                <th class="text-end">Original Value</th>
                                <th class="text-end">Combo Price</th>
                                <th class="text-center">Discount</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var combo in comboStats)
                            {
                                decimal savings = (decimal)combo.TotalItemsValue - (decimal)combo.Price;
                                decimal savingsPercent = combo.TotalItemsValue > 0 ? (savings / (decimal)combo.TotalItemsValue) * 100 : 0;
                                <tr>
                                    <td>@combo.ComboId</td>
                                    <td><strong>@combo.Name</strong></td>
                                    <td>@(combo.Description ?? "-")</td>
                                    <td class="text-center">
                                        <span class="badge bg-info">@combo.ItemCount items</span>
                                    </td>
                                    <td class="text-end text-muted">₹@combo.TotalItemsValue.ToString("N0")</td>
                                    <td class="text-end text-success"><strong>₹@combo.Price.ToString("N0")</strong></td>
                                    <td class="text-center">
                                        @if (combo.DiscountPercentage != null && combo.DiscountPercentage > 0)
                                        {
                                            <span class="badge bg-warning text-dark">@combo.DiscountPercentage%</span>
                                        }
                                        else if (savings > 0)
                                        {
                                            <span class="badge bg-success">Save ₹@savings.ToString("N0")</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        @if (combo.IsActive)
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Inactive</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info text-center">
                    <i class="fas fa-info-circle me-2"></i>No combo packages found.
                </div>
            }
        </div>
    </div>

    <!-- Combo Breakdown -->
    @if (comboStats != null && comboStats.Any())
    {
        <div class="row mt-4">
            @foreach (var combo in comboStats)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100">
                        <div class="card-header bg-white d-flex justify-content-between align-items-center">
                            <h6 class="mb-0">@combo.Name</h6>
                            @if (combo.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Inactive</span>
                            }
                        </div>
                        <div class="card-body">
                            <p class="text-muted small">@(combo.Description ?? "No description")</p>
                            <hr />
                            <h6>Included Items:</h6>
                            @if (combo.Items != null && combo.Items.Count > 0)
                            {
                                <ul class="list-unstyled">
                                    @foreach (var item in combo.Items)
                                    {
                                        <li>
                                            <i class="fas fa-check text-success me-2"></i>
                                            @item.Name <span class="text-muted">(x@item.Quantity)</span>
                                        </li>
                                    }
                                </ul>
                            }
                            else
                            {
                                <p class="text-muted small">No items in this combo</p>
                            }
                        </div>
                        <div class="card-footer bg-white">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="text-muted">Original: <del>₹@combo.TotalItemsValue.ToString("N0")</del></span>
                                <strong class="text-success fs-5">₹@combo.Price.ToString("N0")</strong>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
