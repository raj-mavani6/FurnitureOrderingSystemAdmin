@{
    ViewData["Title"] = "Reports & Analytics";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <h2>
                <i class="fas fa-chart-bar me-2"></i>Reports & Analytics
            </h2>
            <p class="text-muted">Comprehensive business reports and analytics dashboard</p>
        </div>
    </div>

    <!-- Report Cards -->
    <div class="row">
        <!-- Furniture Reports -->
        <div class="col-md-6 col-lg-4 mb-4">
            <div class="card report-card h-100">
                <div class="card-body text-center">
                    <div class="report-icon mb-3">
                        <i class="fas fa-couch fa-3x text-primary"></i>
                    </div>
                    <h4>Furniture Reports</h4>
                    <p class="text-muted mb-3">Furniture performance and sales analysis</p>
                    <a href="@Url.Action("Furniture")" class="btn btn-primary">
                        <i class="fas fa-eye me-1"></i>View Report
                    </a>
                </div>
            </div>
        </div>

        <!-- Category Reports -->
        <div class="col-md-6 col-lg-4 mb-4">
            <div class="card report-card h-100">
                <div class="card-body text-center">
                    <div class="report-icon mb-3">
                        <i class="fas fa-th-large fa-3x text-info"></i>
                    </div>
                    <h4>Category Reports</h4>
                    <p class="text-muted mb-3">Category-wise performance breakdown</p>
                    <a href="@Url.Action("Categories")" class="btn btn-info">
                        <i class="fas fa-eye me-1"></i>View Report
                    </a>
                </div>
            </div>
        </div>

        <!-- Order Reports -->
        <div class="col-md-6 col-lg-4 mb-4">
            <div class="card report-card h-100">
                <div class="card-body text-center">
                    <div class="report-icon mb-3">
                        <i class="fas fa-receipt fa-3x text-warning"></i>
                    </div>
                    <h4>Order Reports</h4>
                    <p class="text-muted mb-3">Track orders by status and performance</p>
                    <a href="@Url.Action("Orders")" class="btn btn-warning">
                        <i class="fas fa-eye me-1"></i>View Report
                    </a>
                </div>
            </div>
        </div>

        <!-- Combo Reports -->
        <div class="col-md-6 col-lg-4 mb-4">
            <div class="card report-card h-100">
                <div class="card-body text-center">
                    <div class="report-icon mb-3">
                        <i class="fas fa-layer-group fa-3x text-purple"></i>
                    </div>
                    <h4>Combo Reports</h4>
                    <p class="text-muted mb-3">Combo packages performance analysis</p>
                    <a href="@Url.Action("Combos")" class="btn btn-secondary">
                        <i class="fas fa-eye me-1"></i>View Report
                    </a>
                </div>
            </div>
        </div>

        <!-- Coupon Reports -->
        <div class="col-md-6 col-lg-4 mb-4">
            <div class="card report-card h-100">
                <div class="card-body text-center">
                    <div class="report-icon mb-3">
                        <i class="fas fa-ticket-alt fa-3x text-success"></i>
                    </div>
                    <h4>Coupon Reports</h4>
                    <p class="text-muted mb-3">Track coupon usage and effectiveness</p>
                    <a href="@Url.Action("Coupons")" class="btn btn-success">
                        <i class="fas fa-eye me-1"></i>View Report
                    </a>
                </div>
            </div>
        </div>

        <!-- Customer Reports -->
        <div class="col-md-6 col-lg-4 mb-4">
            <div class="card report-card h-100">
                <div class="card-body text-center">
                    <div class="report-icon mb-3">
                        <i class="fas fa-users fa-3x text-danger"></i>
                    </div>
                    <h4>Customer Reports</h4>
                    <p class="text-muted mb-3">Customer analytics and behavior insights</p>
                    <a href="@Url.Action("Customer")" class="btn btn-danger">
                        <i class="fas fa-eye me-1"></i>View Report
                    </a>
                </div>
            </div>
        </div>

        <!-- Review Reports -->
        <div class="col-md-6 col-lg-4 mb-4">
            <div class="card report-card h-100">
                <div class="card-body text-center">
                    <div class="report-icon mb-3">
                        <i class="fas fa-star fa-3x text-warning"></i>
                    </div>
                    <h4>Review Reports</h4>
                    <p class="text-muted mb-3">Customer review analysis and ratings</p>
                    <a href="@Url.Action("Reviews")" class="btn btn-warning">
                        <i class="fas fa-eye me-1"></i>View Report
                    </a>
                </div>
            </div>
        </div>

        <!-- Sales Reports -->
        <div class="col-md-6 col-lg-4 mb-4">
            <div class="card report-card h-100">
                <div class="card-body text-center">
                    <div class="report-icon mb-3">
                        <i class="fas fa-dollar-sign fa-3x text-success"></i>
                    </div>
                    <h4>Sales Reports</h4>
                    <p class="text-muted mb-3">View detailed sales analysis and trends</p>
                    <a href="@Url.Action("Sales")" class="btn btn-success">
                        <i class="fas fa-eye me-1"></i>View Report
                    </a>
                </div>
            </div>
        </div>

        <!-- Revenue Reports -->
        <div class="col-md-6 col-lg-4 mb-4">
            <div class="card report-card h-100">
                <div class="card-body text-center">
                    <div class="report-icon mb-3">
                        <i class="fas fa-chart-line fa-3x text-primary"></i>
                    </div>
                    <h4>Revenue Reports</h4>
                    <p class="text-muted mb-3">Revenue analysis by time period</p>
                    <a href="@Url.Action("Revenue")" class="btn btn-primary">
                        <i class="fas fa-eye me-1"></i>View Report
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Export Options -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-download me-2"></i>Export Options
                    </h5>
                </div>
                <div class="card-body">
                    <p class="text-muted">Export reports to CSV for external analysis</p>
                    <div class="row">
                        <div class="col-md-3 mb-2">
                            <a href="@Url.Action("ExportSalesCSV")" class="btn btn-outline-success w-100">
                                <i class="fas fa-file-csv me-1"></i>Sales CSV
                            </a>
                        </div>
                        <div class="col-md-3 mb-2">
                            <a href="@Url.Action("ExportOrdersCSV")" class="btn btn-outline-warning w-100">
                                <i class="fas fa-file-csv me-1"></i>Orders CSV
                            </a>
                        </div>
                        <div class="col-md-3 mb-2">
                            <a href="@Url.Action("ExportCustomersCSV")" class="btn btn-outline-danger w-100">
                                <i class="fas fa-file-csv me-1"></i>Customers CSV
                            </a>
                        </div>
                        <div class="col-md-3 mb-2">
                            <a href="@Url.Action("ExportFurnitureCSV")" class="btn btn-outline-primary w-100">
                                <i class="fas fa-file-csv me-1"></i>Furniture CSV
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
