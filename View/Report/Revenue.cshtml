@model List<FurnitureOrderingSystemAdmin.Models.Order>
@{
    ViewData["Title"] = "Revenue Reports";
    var categoryRevenue = ViewBag.CategoryRevenue as List<dynamic>;
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2>
                        <i class="fas fa-chart-line me-2"></i>Revenue Reports
                    </h2>
                    <p class="text-muted">Revenue analysis by time period</p>
                </div>
                <div>
                    <a href="@Url.Action("Index")" class="btn btn-secondary">
                        <i class="fas fa-arrow-left me-1"></i>Back to Reports
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Period Filter -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="btn-group" role="group">
                <a href="@Url.Action("Revenue", new { period = "today" })" class="btn @(ViewBag.Period == "today" ? "btn-primary" : "btn-outline-primary")">
                    <i class="fas fa-calendar-day me-1"></i>Today
                </a>
                <a href="@Url.Action("Revenue", new { period = "week" })" class="btn @(ViewBag.Period == "week" ? "btn-primary" : "btn-outline-primary")">
                    <i class="fas fa-calendar-week me-1"></i>This Week
                </a>
                <a href="@Url.Action("Revenue", new { period = "month" })" class="btn @(ViewBag.Period == "month" ? "btn-primary" : "btn-outline-primary")">
                    <i class="fas fa-calendar-alt me-1"></i>This Month
                </a>
                <a href="@Url.Action("Revenue", new { period = "year" })" class="btn @(ViewBag.Period == "year" ? "btn-primary" : "btn-outline-primary")">
                    <i class="fas fa-calendar me-1"></i>This Year
                </a>
                <a href="@Url.Action("Revenue", new { period = "all" })" class="btn @(ViewBag.Period == "all" ? "btn-primary" : "btn-outline-primary")">
                    <i class="fas fa-history me-1"></i>All Time
                </a>
            </div>
        </div>
    </div>

    <!-- Revenue Summary Cards -->
    <div class="row mb-4">
        <div class="col-md-3 mb-3">
            <div class="card bg-primary text-white">
                <div class="card-body">
                    <h6 class="card-title">Total Orders</h6>
                    <h3 class="mb-0">@ViewBag.TotalOrders</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <h6 class="card-title">Total Revenue</h6>
                    <h3 class="mb-0">₹@ViewBag.TotalRevenue.ToString("N0")</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card bg-danger text-white">
                <div class="card-body">
                    <h6 class="card-title">Total Discount</h6>
                    <h3 class="mb-0">₹@ViewBag.TotalDiscount.ToString("N0")</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card bg-info text-white">
                <div class="card-body">
                    <h6 class="card-title">Net Revenue</h6>
                    <h3 class="mb-0">₹@ViewBag.NetRevenue.ToString("N0")</h3>
                </div>
            </div>
        </div>
    </div>

    <!-- Average Order Value -->
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-0">Average Order Value</h6>
                        </div>
                        <div>
                            <h3 class="mb-0 text-success">₹@ViewBag.AverageOrderValue.ToString("N0")</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Category-wise Revenue -->
    @if (categoryRevenue != null && categoryRevenue.Any())
    {
        <div class="row mb-4">
            <div class="col-lg-6 mb-4">
                <div class="card h-100">
                    <div class="card-header bg-white">
                        <h5 class="mb-0 text-dark">
                            <i class="fas fa-th-large me-2 text-primary"></i>Category-wise Revenue
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="chart-container" style="height: 300px;">
                            <canvas id="categoryRevenueChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 mb-4">
                <div class="card h-100">
                    <div class="card-header bg-white">
                        <h5 class="mb-0 text-dark">
                            <i class="fas fa-table me-2"></i>Revenue Breakdown
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-bordered table-hover">
                                <thead class="table-light">
                                    <tr>
                                        <th>Category Name</th>
                                        <th class="text-center">Items Sold (Qty)</th>
                                        <th class="text-end">Total Revenue</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var cat in categoryRevenue)
                                    {
                                        <tr>
                                            <td><strong>@cat.CategoryName</strong></td>
                                            <td class="text-center">
                                                <span class="badge bg-secondary">@cat.OrderItemCount</span>
                                            </td>
                                            <td class="text-end">
                                                <strong>₹@cat.Revenue.ToString("N0")</strong>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot class="table-light">
                                    <tr>
                                        <th>Total:</th>
                                        <th class="text-center">@categoryRevenue.Sum(x => (int)x.OrderItemCount)</th>
                                        <th class="text-end">₹@categoryRevenue.Sum(x => (decimal)x.Revenue).ToString("N0")</th>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Revenue by Date -->
    @if (Model != null && Model.Any())
    {
        var revenueByDate = Model
            .GroupBy(o => o.OrderDate.Date)
            .Select(g => new
            {
                Date = g.Key,
                Orders = g.Count(),
                Revenue = g.Sum(o => o.TotalAmount),
                Discount = g.Sum(o => o.DiscountAmount ?? 0),
                NetRevenue = g.Sum(o => o.TotalAmount - (o.DiscountAmount ?? 0))
            })
            .OrderByDescending(x => x.Date)
            .ToList();

        <div class="card mb-4">
            <div class="card-header bg-white">
                <h5 class="mb-0">Daily Revenue Breakdown</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Orders</th>
                                <th>Total Revenue</th>
                                <th>Discount</th>
                                <th>Net Revenue</th>
                                <th>Avg Order Value</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in revenueByDate)
                            {
                                var avgOrderValue = item.Orders > 0 ? item.Revenue / item.Orders : 0;
                                <tr>
                                    <td><strong>@item.Date.ToString("dd MMM yyyy")</strong></td>
                                    <td>@item.Orders</td>
                                    <td>₹@item.Revenue.ToString("N0")</td>
                                    <td class="text-danger">-₹@item.Discount.ToString("N0")</td>
                                    <td class="text-success"><strong>₹@item.NetRevenue.ToString("N0")</strong></td>
                                    <td>₹@avgOrderValue.ToString("N0")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr>
                                <th>Totals:</th>
                                <th>@revenueByDate.Sum(x => x.Orders)</th>
                                <th>₹@revenueByDate.Sum(x => x.Revenue).ToString("N0")</th>
                                <th class="text-danger">-₹@revenueByDate.Sum(x => x.Discount).ToString("N0")</th>
                                <th class="text-success">₹@revenueByDate.Sum(x => x.NetRevenue).ToString("N0")</th>
                                <th></th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        <!-- Revenue Insights -->
        <div class="card mb-4">
            <div class="card-header bg-white">
                <h5 class="mb-0 text-dark">
                    <i class="fas fa-lightbulb me-2 text-warning"></i>Revenue Insights
                </h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4">
                        <h6 class="text-muted">Best Day</h6>
                        @{
                            var bestDay = revenueByDate.OrderByDescending(x => x.NetRevenue).FirstOrDefault();
                            if (bestDay != null)
                            {
                                <p class="mb-0"><strong>@bestDay.Date.ToString("dd MMM yyyy")</strong></p>
                                <small class="text-success">₹@bestDay.NetRevenue.ToString("N0")</small>
                            }
                        }
                    </div>
                    <div class="col-md-4">
                        <h6 class="text-muted">Average Daily Revenue</h6>
                        <p class="mb-0"><strong>₹@revenueByDate.Average(x => x.NetRevenue).ToString("N0")</strong></p>
                    </div>
                    <div class="col-md-4">
                        <h6 class="text-muted">Average Orders Per Day</h6>
                        <p class="mb-0"><strong>@revenueByDate.Average(x => x.Orders).ToString("F1")</strong></p>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-body">
                <div class="alert alert-info text-center">
                    <i class="fas fa-info-circle me-2"></i>No revenue data available for the selected period.
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    @{
        var labels = new List<string>();
        var data = new List<decimal>();
        var hasData = false;

        if (categoryRevenue != null && categoryRevenue.Any())
        {
            hasData = true;
            labels = categoryRevenue.Select(c => (string)c.CategoryName).ToList();
            data = categoryRevenue.Select(c => (decimal)c.Revenue).ToList();
        }
    }

    @if (hasData)
    {
        <script>
            // Data from Server
            var chartLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(labels));
            var chartData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(data));

            var ctx = document.getElementById('categoryRevenueChart').getContext('2d');
            new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: chartLabels,
                    datasets: [{
                        data: chartData,
                        backgroundColor: [
                            '#0d6efd', '#198754', '#dc3545', '#ffc107', '#0dcaf0',
                            '#6f42c1', '#fd7e14', '#20c997', '#6c757d', '#d63384'
                        ]
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom'
                        }
                    }
                }
            });
        </script>
    }
}
